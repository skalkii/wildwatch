# VideoDB — official env var name is VIDEO_DB_API_KEY (underscored).
# Get key at https://console.videodb.io/. Hackathon credits unlock 1h before kickoff.
VIDEO_DB_API_KEY=

# Optional alternative auth (mutually exclusive with VIDEO_DB_API_KEY):
# VIDEO_DB_SESSION_TOKEN=

# Telegram bot — BotFather → /newbot → copy token; chat_id from
# https://api.telegram.org/bot<TOKEN>/getUpdates after first DM to bot.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Public URL where VideoDB callbacks reach our FastAPI app.
# Local dev: http://localhost:8000 (no callbacks). Live: cloudflared tunnel URL.
# bootstrap.py rejects non-https URLs that aren't localhost — VideoDB POSTs
# alerts cross-internet to whatever URL we register here.
WEBHOOK_BASE_URL=http://localhost:8000

# CSRF / Origin guard — mutating /api/* requests are rejected unless the
# Origin header matches localhost/127.0.0.1/0.0.0.0 or one of the hosts in
# WILDWATCH_ALLOWED_ORIGINS (comma-separated). For trusted CLI clients
# (curl, scripts) that don't send Origin, set WILDWATCH_ALLOW_NO_ORIGIN=1.
# WILDWATCH_ALLOWED_ORIGINS=
# WILDWATCH_ALLOW_NO_ORIGIN=

# Webhook auth — shared secret for /webhook/{tier}. When set, every
# callback (VideoDB rtstream alerts AND our own Path-B sweeps + the
# correlation engine) must carry header `X-WildWatch-Secret: <value>`.
# Without it, /webhook/ accepts anyone — fine for pure-localhost demo,
# DANGEROUS over a cloudflared/ngrok tunnel. Path-B + correlation read
# this var themselves, so setting it is symmetric.
# WILDWATCH_WEBHOOK_SECRET=

# Reverse-proxy mode — set to 1 if this server runs behind nginx /
# Cloudflare / ALB. Upload rate limiter then reads the FIRST IP from
# X-Forwarded-For instead of the TCP peer (which would be the proxy
# itself, collapsing all clients into one shared bucket). NEVER set
# this in a direct-exposure deployment — a remote client can spoof
# X-Forwarded-For to bypass per-IP rate limits.
# WILDWATCH_TRUSTED_PROXY=

# WebSocket listener output dir (wildwatch/ws_listener.py writes
# `videodb_ws_id` and `videodb_events.jsonl` here). Default: /tmp.
# VIDEODB_EVENTS_DIR=/tmp
